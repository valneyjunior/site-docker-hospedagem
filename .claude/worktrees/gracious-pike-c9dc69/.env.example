# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=troque_por_senha_forte

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_REPLY=comercial@hostweb.com.br

# ── URLs (ajuste para seu domínio em produção) ────────────────────────────────
SUCCESS_URL=http://localhost/sucesso?session_id={CHECKOUT_SESSION_ID}
CANCEL_URL=http://localhost/?cancelado=1
VERIFICACAO_URL=https://hostweb.com.br/verificar-aceite

# ── WHM / cPanel ──────────────────────────────────────────────────────────────
# Endereço do servidor WHM (IP ou hostname, sem protocolo)
WHM_HOST=servidor.hostweb.com.br
# Porta padrão WHM SSL (2087)
WHM_PORT=2087
# Usuário root ou reseller do WHM
WHM_USER=root
# API Token gerado em WHM > Development > Manage API Tokens
WHM_TOKEN=
# true se o servidor WHM tiver certificado SSL válido; false para autoassinado
WHM_VERIFY_SSL=false

# ── Notificações internas ──────────────────────────────────────────────────────
# E-mail que receberá alertas de provisionamento (novo cPanel, erros, manuais)
EMAIL_NOTIFY_INTERNAL=comercial@hostweb.com.br
# Slack Incoming Webhook URL (deixe vazio para desativar notificações Slack)
SLACK_WEBHOOK_URL=

# ── Flask ─────────────────────────────────────────────────────────────────────
PORT=8080
